---
import Base from '../layouts/Base.astro';
import fs from 'node:fs';
import path from 'node:path';

const base = import.meta.env.BASE_URL;

// Written by the bookshelf-echo publisher (SnapshotJob) and synced into public/ by its
// site-publisher sidecar. Absent on a fresh clone and before the first sync, so
// the page renders a placeholder rather than failing the build.
let snap: any = null;
try {
  snap = JSON.parse(
    fs.readFileSync(path.join(process.cwd(), 'public/data/metrics/latest.json'), 'utf-8'),
  );
} catch {
  snap = null;
}

const nf = new Intl.NumberFormat('en-US');
const num = (n: number) => nf.format(n ?? 0);
const compact = (n: number) =>
  new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 1 }).format(n ?? 0);
// Spend is fractions of a cent, so it needs 4 dp to say anything; the budget is a
// round config value and reads wrong at that precision ($0.5000).
const usd = (n: number) => '$' + (n ?? 0).toFixed((n ?? 0) >= 1 ? 2 : 4);
const usdRound = (n: number) => '$' + (n ?? 0).toFixed(2);
const pct = (r: number) => Math.max(0, Math.min(100, r * 100));

// Severity for a meter fill: accent → warning → danger. Every use is paired with
// an icon + label chip, so state never rests on colour alone.
const sev = (ratio: number | null) =>
  ratio == null ? 'accent' : ratio >= 1 ? 'critical' : ratio >= 0.8 ? 'warning' : 'accent';
// The chip speaks the status palette, where healthy is "good", not the accent.
const chipOf = (s: string) => (s === 'accent' ? 'good' : s);
const ICON: Record<string, string> = { good: '✓', warning: '!', critical: '✕' };

const STATES = ['RECEIVED', 'ENRICHED', 'DIGESTED', 'PUBLISHED', 'DUPLICATE', 'FAILED'];
const STATE_LABEL: Record<string, string> = {
  RECEIVED: '已接收',
  ENRICHED: '已擴充',
  DIGESTED: '已摘要',
  PUBLISHED: '已發布',
  DUPLICATE: '重複',
  FAILED: '失敗',
};
// Only these have consumers. The retry ladder and the DLQ are parking lots by
// design (ADR-004), so "0 consumers" there is health, not a stall.
const WORK_QUEUES = ['ingest.q', 'digest.q', 'publish.q'];

const items = snap?.items ?? {};
const stateRows = STATES.map((s) => ({ state: s, label: STATE_LABEL[s], count: items[s] ?? 0 }));
const stateMax = Math.max(1, ...stateRows.map((r) => r.count));

const queues = (snap?.queues ?? []).slice();
const rank = (n: string) => (WORK_QUEUES.includes(n) ? 0 : n === 'dlq.q' ? 1 : 2);
queues.sort((a: any, b: any) => rank(a.name) - rank(b.name) || a.name.localeCompare(b.name));
const queueMax = Math.max(1, ...queues.map((q: any) => q.messages ?? 0));
const dlqDepth = queues.find((q: any) => q.name === 'dlq.q')?.messages ?? 0;

const llm = snap?.llmToday ?? { costUsd: 0, inputTokens: 0, outputTokens: 0, calls: 0 };
const budget = snap?.limits?.dailyBudgetUsd ?? null;
const digestLimit = snap?.limits?.dailyDigestLimit ?? null;
const costRatio = budget ? llm.costUsd / budget : null;
const digestRatio = digestLimit ? llm.calls / digestLimit : null;

const costSev = sev(costRatio);
const costChip = chipOf(costSev);
const COST_TEXT: Record<string, string> = {
  good: '預算充裕',
  warning: '接近每日預算',
  critical: '已達預算，斷路器停放中',
};
const digestSev = sev(digestRatio);

const captured = snap?.capturedAt
  ? new Date(snap.capturedAt).toISOString().replace('T', ' ').slice(0, 16) + ' UTC'
  : null;
---

<Base
  title="Bookshelf Echo — 系統健康"
  description="bookshelf-echo pipeline 的健康指標：佇列深度、項目狀態、LLM 花費與 DLQ"
>
  <p><a class="back" href={base}>← 回首頁</a></p>

  <h2>系統健康</h2>

  {
    !snap && (
      <p class="empty">
        尚無快照 — pipeline 首次同步 <code>data/metrics/latest.json</code> 後會自動出現。
      </p>
    )
  }

  {
    snap && (
      <div class="viz">
        <p class="captured">快照時間 {captured} · 由 pipeline 定期寫入</p>

        <section class="card hero">
          <p class="label">今日 LLM 花費</p>
          <p class="hero-value">{usd(llm.costUsd)}</p>
          {budget != null && (
            <>
              <div class="meter" style={`--meter:var(--sev-${costSev});--fill:${pct(costRatio!)}%`}>
                <div class="meter-fill" />
              </div>
              <p class="sub">
                <span class={`chip chip-${costChip}`}>
                  <span class="ico" aria-hidden="true">
                    {ICON[costChip]}
                  </span>
                  {COST_TEXT[costChip]}
                </span>
                <span>
                  每日預算 {usdRound(budget)} · 已用 {Math.round(costRatio! * 100)}%
                </span>
              </p>
            </>
          )}
          <p class="sub muted">
            {num(llm.calls)} 次呼叫 · {compact(llm.inputTokens)} in / {compact(llm.outputTokens)} out
            tokens
          </p>
        </section>

        <div class="kpis">
          <section class="card">
            <p class="label">今日摘要</p>
            <p class="value">
              {num(llm.calls)}
              {digestLimit != null && <span class="of"> / {digestLimit}</span>}
            </p>
            {digestRatio != null && (
              <div
                class="meter"
                style={`--meter:var(--sev-${digestSev});--fill:${pct(digestRatio)}%`}
              >
                <div class="meter-fill" />
              </div>
            )}
            <p class="sub muted">每日高價值上限，超出者留在佇列等下一個視窗</p>
          </section>

          <section class="card">
            <p class="label">24 小時新進</p>
            <p class="value">{num(snap.receivedLast24h)}</p>
            <p class="sub muted">producers 送入 pipeline 的項目</p>
          </section>

          <section class="card">
            <p class="label">DLQ 停放</p>
            <p class="value">{num(dlqDepth)}</p>
            <p class="sub">
              <span class={`chip chip-${dlqDepth > 0 ? 'critical' : 'good'}`}>
                <span class="ico" aria-hidden="true">
                  {dlqDepth > 0 ? ICON.critical : ICON.good}
                </span>
                {dlqDepth > 0 ? '需要 ops dlq replay' : '無停放訊息'}
              </span>
            </p>
          </section>
        </div>

        <h3>項目狀態</h3>
        <div class="bars">
          {stateRows.map((r) => (
            <div class="bar-row">
              <span class="bar-label">{r.label}</span>
              <span class="bar-track">
                <span class="bar" style={`--w:${r.count / stateMax}`} />
                <span class="bar-value">{num(r.count)}</span>
                {r.state === 'FAILED' && r.count > 0 && (
                  <span class="chip chip-critical">
                    <span class="ico" aria-hidden="true">
                      {ICON.critical}
                    </span>
                    需要調查
                  </span>
                )}
              </span>
            </div>
          ))}
        </div>

        <h3>佇列深度</h3>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>佇列</th>
                <th class="depth-col">深度</th>
                <th class="n">訊息</th>
                <th class="n">消費者</th>
              </tr>
            </thead>
            <tbody>
              {queues.map((q: any) => (
                <tr>
                  <td>
                    <code>{q.name}</code>
                  </td>
                  <td class="depth-col">
                    <span
                      class="qbar"
                      style={`width:${((q.messages ?? 0) / queueMax) * 100}%`}
                      title={`ready ${num(q.messages_ready)} · unacked ${num(q.messages_unacknowledged)}`}
                    />
                  </td>
                  <td class="n">{num(q.messages)}</td>
                  <td class="n">
                    {num(q.consumers)}
                    {WORK_QUEUES.includes(q.name) && (q.consumers ?? 0) === 0 && (
                      <span class="chip chip-warning">
                        <span class="ico" aria-hidden="true">
                          {ICON.warning}
                        </span>
                        無消費者
                      </span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="foot-note">
          <code>retry.*</code> 與 <code>dlq.q</code> 依設計就沒有消費者（ADR-004）：它們是停放區，靠 TTL
          到期後自動退回原佇列。
        </p>
      </div>
    )
  }
</Base>

<style>
  /* Marks use the validated palette: one blue hue for every data bar (identity is
     not the job here, magnitude is), plus the fixed status palette for state.
     Validated against this site's card surfaces — #f9fafb light, #161a22 dark. */
  .viz {
    --series-1: #2a78d6;
    --sev-accent: #2a78d6;
    --sev-good: #0ca30c;
    --sev-warning: #fab219;
    --sev-critical: #d03b3b;
  }
  @media (prefers-color-scheme: dark) {
    .viz {
      /* Status steps are fixed across modes; only the blue is re-stepped for the
         dark surface. */
      --series-1: #3987e5;
      --sev-accent: #3987e5;
    }
  }

  .captured,
  .empty {
    color: var(--muted);
    font-size: 0.9rem;
    margin: 0 0 1.25rem;
  }

  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.1rem;
  }
  .label {
    color: var(--muted);
    font-size: 0.85rem;
    margin: 0;
  }
  /* Hero figure: the one number the page leads with. Proportional figures — at
     display size tabular-nums reads loose. */
  .hero-value {
    font-size: 3rem;
    font-weight: 600;
    line-height: 1.15;
    margin: 0.2rem 0 0.6rem;
  }
  .value {
    font-size: 1.6rem;
    font-weight: 600;
    margin: 0.15rem 0 0.5rem;
  }
  .value .of {
    color: var(--muted);
    font-size: 1rem;
    font-weight: 400;
  }
  .sub {
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }
  .sub.muted {
    color: var(--muted);
  }

  /* Meter: fill carries severity; the track is a lighter step of that same ramp,
     so the state reads across the whole bar. */
  .meter {
    height: 8px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--meter) 22%, var(--card));
    overflow: hidden;
  }
  .meter-fill {
    display: block;
    height: 100%;
    width: var(--fill);
    background: var(--meter);
    border-radius: 999px;
  }

  .kpis {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  /* Status chip: colour never travels alone — an icon and a label ride with it. */
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    white-space: nowrap;
    color: var(--fg);
  }
  .chip .ico {
    display: inline-grid;
    place-items: center;
    width: 1.05em;
    height: 1.05em;
    border-radius: 50%;
    font-size: 0.72em;
    font-weight: 700;
    color: #fff;
  }
  .chip-good .ico {
    background: var(--sev-good);
  }
  .chip-warning .ico {
    background: var(--sev-warning);
    color: #1a1a19;
  }
  .chip-critical .ico {
    background: var(--sev-critical);
  }

  .bars {
    display: grid;
    gap: 0.5rem;
  }
  .bar-row {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    align-items: center;
    gap: 0.75rem;
  }
  .bar-label {
    color: var(--muted);
    font-size: 0.85rem;
  }
  .bar-track {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }
  /* Thin mark, square at the baseline, 4px rounded at the data end. The track
     reserves room for the tip label, so a full-scale bar can never push its own
     value out of the container. */
  .bar {
    height: 14px;
    width: calc(var(--w) * (100% - 4rem));
    background: var(--series-1);
    border-radius: 0 4px 4px 0;
    flex: 0 0 auto;
  }
  /* Value rides the tip, outside the mark — never clipped by it. */
  .bar-value {
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    color: var(--fg);
  }

  .table-wrap {
    overflow-x: auto;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }
  th,
  td {
    text-align: left;
    padding: 0.45rem 0.6rem 0.45rem 0;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  th {
    color: var(--muted);
    font-weight: 500;
  }
  .n {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  td.n {
    white-space: nowrap;
  }
  td.n .chip {
    margin-left: 0.4rem;
  }
  .depth-col {
    width: 45%;
  }
  td.depth-col {
    padding-right: 1rem;
  }
  .qbar {
    display: block;
    height: 10px;
    min-width: 0;
    background: var(--series-1);
    border-radius: 0 4px 4px 0;
  }
  .foot-note {
    color: var(--muted);
    font-size: 0.8rem;
    margin-top: 0.9rem;
  }
</style>
